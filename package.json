{
  "name": "worktime-tracker-vscode",
  "displayName": "Work Time Tracker",
  "description": "Simple work time tracker with a status bar button",
  "version": "0.0.1",
  "publisher": "muchiNoChi",
  "license": "MIT",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/muchiNoChi/worktime-tracker-vscode"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "timeTracker.toggle",
        "title": "Work Time Tracker: Toggle Task"
      }
    ],
    "configuration": {
      "title": "Work Time Tracker",
      "properties": {
        "timeTracker.filePath": {
          "type": "string",
          "default": "~/time-tracking.txt",
          "description": "Absolute path to the time tracking file"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.110.0",
    "typescript": "^5.9.3"
  }
}
